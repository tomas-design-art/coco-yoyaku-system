# ── 基本設定 ──
ENVIRONMENT=development
# ENVIRONMENT=production
APP_TITLE=予約管理システム

# ── データベース ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/reservation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reservation

# ── セキュリティ ──
# 本番では必ず変更: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── CORS（本番で外部からアクセスする場合） ──
CORS_ORIGINS=
CHATBOT_ALLOWED_ORIGINS=

# ── AI / 外部API ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── LINE連携 ──
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_USER_ID=
# システム異常(SOS)通知の送信先（開発者）
ADMIN_LINE_DEVELOPER_USER_ID=
LINE_CHANNEL_DEVELOPER_ACCESS_TOKEN=

# ── メール取得 ──
MAIL_PROVIDER=gmail

# iCloud IMAP を使う場合:
# MAIL_PROVIDER=icloud-imap
# ICLOUD_EMAIL=your_apple_id@icloud.com
# ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# IMAP_HOST=imap.mail.me.com
# IMAP_PORT=993
# IMAP_MAILBOX=INBOX
# HOTPEPPER_SENDER_FILTERS=SALON BOARD <yoyaku_system@salonboard.com>
# HOTPEPPER_POLL_INTERVAL_MINUTES=5
# HOTPEPPER_POLL_FETCH_LIMIT=50
# HOTPEPPER_POLL_MAX_RETRIES=3
# HOTPEPPER_POLL_RETRY_BASE_SECONDS=2
